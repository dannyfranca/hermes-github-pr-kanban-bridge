[Unit]
Description=Hermes GitHub PR activity to Kanban unblock bridge
Documentation=https://github.com/dannyfranca/hermes-github-pr-kanban-bridge

[Service]
Type=oneshot
Environment=HERMES_HOME=/home/agent/.hermes/profiles/coder
Environment=HERMES_PROFILE=coder
Environment=HERMES_KANBAN_BOARD=default
WorkingDirectory=/home/agent/git/hermes-github-pr-kanban-bridge
ExecStart=/home/agent/git/hermes-github-pr-kanban-bridge/scripts/github_pr_kanban_bridge.py --config /home/agent/.hermes/profiles/coder/github-pr-kanban-bridge/config.json
